<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sunset Tech 2070 splash background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0D0D" />
        </shape>
    </item>
    <!-- Sunset radial glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="700"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#66FF5A1F"
                android:centerColor="#33FF7A3D"
                android:endColor="#000D0D0D" />
        </shape>
    </item>
</layer-list>
