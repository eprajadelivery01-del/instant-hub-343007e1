<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Sunset Tech 2070 splash background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D0D0D" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600"
                android:centerX="0.5"
                android:centerY="0.35"
                android:startColor="#33FF5A1F"
                android:centerColor="#1AFF5A1F"
                android:endColor="#000D0D0D" />
        </shape>
    </item>
</layer-list>
